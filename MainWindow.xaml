                                <TextBox
                                    x:Name="chats_box"
                                    
                                    Background="#8B949E"
                                    Foreground="#E0E0E0"
                                    BorderThickness="1.5"
                                    BorderBrush="Cyan"
                                    FontSize="14"
                                    VerticalScrollBarVisibility="Auto"
                                    TextWrapping="Wrap"
                                    IsReadOnly="True"
                                    AcceptsReturn="True"
                                    />


                            </ScrollViewer>
                            <!--left, top, right, bottom-->

                            <!--input row: textbox + send button-->

                            <StackPanel
                                   
                                Orientation="Horizontal"
                                Grid.Row="1"
                                Margin="10,10,10,15"
                                >

                                <TextBox           
                                    x:Name="question_box"
                                    Height="50"
                                    
                                    Margin="0,0,10,0"
                                    Background="White"
                                    BorderBrush="#39FF14"
