                    <!-- Login form -->
                    <StackPanel 
                        x:Name="loginform_panel"
                        Visibility="Visible"
                        Grid.Row="2" 
                        Width="370"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Margin="0,2,0,25">


                        <Rectangle 
                            Height="1" 
                            Fill="#30363D" 
                            Margin="0,0,0,20"/>

