<Window x:Class="CyberAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberAwarenessBot"
        mc:Ignorable="d"
        Title="HAPPYCODER BOT" Height="780" Width="850">

    <Window.Resources>
        <Style x:Key="GlowCyan" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00E5FF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0" Opacity="0.85"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlowGreen" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#39FF14"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#39FF14" BlurRadius="10" ShadowDepth="0" Opacity="0.75"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#00E5FF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#00E5FF"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#00E5FF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F2937"/>
                    <Setter Property="BorderBrush" Value="#00E5FF"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0D1117"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>


    <Grid><!--start of parent grid-->

        <!-- Drop shadow around entire window -->
        <!-- Outer border: provides rounded corners, background, and a visible border line -->
        <Border
            x:Name="loginborder"
            CornerRadius="12" 
            Background="#0D1117"
            BorderBrush="#30363D" 
            BorderThickness="1">

            <!-- Visual effect: soft black drop shadow behind the border -->
            <Border.Effect>

                <DropShadowEffect 
                    Color="#000000" 
                    BlurRadius="30" 
                    ShadowDepth="0" 
                    Opacity="0.7"/>

            </Border.Effect>

            <!-- Main layout grid: splits into title bar row and content row -->

            <Grid 
                x:Name="layout_grid"
                Visibility="Visible"
                >

                <Grid.RowDefinitions>
                    <!--fixed height 44px for custom title bar-->
                    <RowDefinition Height="44"/>
                    <!-- title bar - star means taking all the remaining space for main content -->
                    <RowDefinition Height="*"/>
                    <!-- content -->
                </Grid.RowDefinitions>

                <!-- ── Custom title bar ── -->
                <Border 
                    Grid.Row="0" 
                    CornerRadius="12,12,0,0"
                    Background="#161B22"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                    <!-- Event: allows dragging the window -->

                    <Grid 
                        x:Name="titlebar_grid"
                        Visibility="Visible"                       
                        >

                        <TextBlock 
                           Text="HAPPYCODER  *  Cybersecurity Awareness Bot"
                           Foreground="#8B949E" 
                           FontFamily="Consolas" 
                           FontSize="11"
                           VerticalAlignment="Center" 
                           Margin="16,0,0,0"/>

                        <!--close buttom-->
                        <Button 
                            
                            Content="✕" 
                            Click="CloseBtn_Click"
                            HorizontalAlignment="Right" 
                            Margin="0,0,8,0"
                            Width="28" Height="28"
                            Background="Transparent" 
                            Foreground="#8B949E"
                            BorderThickness="0" 
                            FontSize="14" 
                            Cursor="Hand"
                            VerticalAlignment="Center"/>

                    </Grid>
                    <!--end of titlebar grid-->

                </Border>


                <!--start of main content area-->
                <Grid 
                    x:Name="logo_grid"
                    Visibility="Visible"
                    Grid.Row="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <!--ASCII Logo-->

                    <Border 
                        Grid.IsSharedSizeScope="True"
                        Background="#0D1117"
                        BorderBrush="Aqua"
                        BorderThickness="0,0,0,1"
                        Padding="10,14,10,10">

                        <TextBlock
                            
                            Style="{StaticResource GlowCyan}"
                            FontSize="10"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            xml:space="preserve"
                            >
