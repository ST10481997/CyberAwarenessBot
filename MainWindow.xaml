                        Width="10" 
                        Height="10" 
                        Fill="#39FF14" 
                        Margin="0,0,6,0">

                                <Ellipse.Effect>
                                    <DropShadowEffect 
                                Color="#39FF14" 
                                BlurRadius="6" 
                                ShadowDepth="0" 
                                Opacity="0.9"/>
                                </Ellipse.Effect>

                            </Ellipse>

                            <TextBlock 
                        Text="HAPPYCODER  ·  Cybersecurity Awareness Bot  v2.0"
                        Foreground="#8B949E" 
                        FontFamily="Consolas" 
                        FontSize="11"
                        VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window controls -->
                        <StackPanel 
                Orientation="Horizontal" 
                HorizontalAlignment="Right"
                VerticalAlignment="Center" 
                Margin="0,0,8,0">

                            <Button 
                                Content="─" 
                                Click="minimise_button"                  
                                Width="28" 
                                Height="28" 
                                Background="Transparent"
                                Foreground="#8B949E" 
                                BorderThickness="0"
                                FontSize="14" 
                                Cursor="Hand" 
                                VerticalAlignment="Center"/>

                            <Button 
                    Content="✕" 
                                Click="close_buttonclick"
                    Width="28" 
                    Height="28" 
                    Background="Transparent"
                    Foreground="#8B949E" 
                    BorderThickness="0"
                    FontSize="14" 
                    Cursor="Hand" 
                    VerticalAlignment="Center"/>
                        </StackPanel>

                    </Grid>
                </Border>



                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <!-- sidebar -->
                        <ColumnDefinition Width="*"/>
                        <!-- chat -->
                    </Grid.ColumnDefinitions>



                    <!-- SIDEBAR -->
