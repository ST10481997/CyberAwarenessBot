                        ASK ANYTHING ABOUT CYBERSECURITY


                                </TextBlock>


                            </Grid>
                            <!--end of full asci logo grid-->

                        </Border>
                        <!--end of full asci logo banner-->




                        <Grid
                    x:Name="chat_grid"
                    Visibility="Visible"
                            Grid.Row="1"
                            Grid.RowSpan="2"
                    >
                            <!--start of chat grid-->

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>

                            </Grid.RowDefinitions>

                            <ScrollViewer
                        Grid.Row="0"
                        x:Name="chats_scroll"
                        Margin="10,10,10,10"
                        VerticalScrollBarVisibility="Auto"              
