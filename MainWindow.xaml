                            Foreground="#00E5FF"
                            FontFamily="Consolas" 
                            FontSize="13" 
                            FontWeight="Bold"
                            Margin="0,0,0,6"/>

                        <TextBox 
                            x:Name="NameBox"
                            Height="44"
                            Foreground="DarkBlue"
                            FontWeight="Bold"
                             />

                        <TextBlock 
                            x:Name="ValidationMsg"
                            Foreground="#FF4444" 
                            FontFamily="Consolas" 
                            FontSize="9"
                            Margin="0,4,0,0" 
                            Visibility="Collapsed" 
                            TextWrapping="Wrap"/>

                        <Rectangle 
                            Height="1" 
                            Fill="#30363D" 
                            Margin="0,20,0,20"/>

                        <Button
                            Style="{StaticResource CyberButton}"
                            Height="30"
                            Width="250"
                            Content="Enter Chat ->"
                            Click="EnterButton_Click"/>

                    </StackPanel>


                </Grid>
                <!--end of logo grid-->
                <!--end of main content area-->
            </Grid>
            <!--end of layout grid-->


        </Border>
        <!--end of window border-->

        <!--start of messaage window-->


        <!-- Outer shadow container -->
