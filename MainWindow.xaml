                Grid.Column="0" 
                Background="#161B22"
                BorderBrush="#30363D" 
                BorderThickness="0,0,1,0"
                CornerRadius="0,0,0,12">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Scrollable top area -->
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14,16,14,10">


                                    <!-- ASCII robot -->
