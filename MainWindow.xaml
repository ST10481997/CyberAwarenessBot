                                    <TextBlock 
                    Text="Cybersecurity Bot" 
                    Foreground="#8B949E"
                    FontFamily="Consolas" 
                    FontSize="10"
                    HorizontalAlignment="Center" 
                    Margin="0,2,0,0"/>

                                    <Rectangle Height="1" Fill="#30363D" Margin="0,12,0,12"/>

                                    <!-- User info -->
                                    <TextBlock 
                    Text="LOGGED IN AS" 
                    Foreground="#8B949E"
                    FontFamily="Consolas" 
                    FontSize="9" 
                    Margin="0,0,0,4"/>
                                    <TextBlock 
                    x:Name="SidebarUserName"
                    Foreground="#E6EDF3" 
                    FontFamily="Consolas"
                    FontSize="13" 
                    FontWeight="Bold"/>

                                    <Rectangle Height="1" Fill="#30363D" Margin="0,12,0,8"/>

                                    <!-- Sentiment display -->
                                    <TextBlock 
                    Text="CURRENT MOOD" 
                    Foreground="#8B949E"
                    FontFamily="Consolas" 
                    FontSize="9" 
                    Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse 
                        x:Name="MoodDot" 
                        Width="10" Height="10"
                        Fill="#8B949E" 
                        Margin="0,0,6,0" 
                        VerticalAlignment="Center"/>
                                        <TextBlock 
                        x:Name="MoodLabel" 
                        Text="Neutral"
                        Foreground="#8B949E" 
                        FontFamily="Consolas" 
                        FontSize="11"/>
                                    </StackPanel>

                                    <Rectangle Height="1" Fill="#30363D" Margin="0,12,0,8"/>
                                    
                                    <!--===============Part 3: new feature buttons==============-->
                                    <TextBlock 
                                        Text="FEATURES"
                                        Foreground="#39FF14"
                                        FontFamily="Consolas"
                                        FontWeight="Bold"
                                        FontSize="10"
                                        Margin="0,0,0,6"                                       
                                        />
                                    
                                    <!--Quiz button-->
                                    <Button 
                                        
                                        Content="START QUIZ"
                                        Click="StartQuizButtton_Click"
                                        />
                                    
                                    <!--show Tasks Button-->
                                    <Button
                                        Content="MY TASKS"
                                        Click="ShowTaskButton_Click"
                                        />
                                    
                                    <!--Activity Log Button-->
                                    <Button
                                        Content="ACTIVITY LOG"
                                        Click="ShowLogButton_Click"
                                        />
                                    
                                    <!--Help Button-->
                                    <Button
                                        
                                        Content="HELP"
                                        Click="HelpButton_Click"
                                        />



                                    <TextBlock 
                    Text="QUICK TOPICS" 
                    Foreground="#8B949E"
                    FontFamily="Consolas" 
                    FontSize="9" 
                    Margin="0,0,0,6"/>

                                    <!-- Quick topic buttons will be added here dynamically -->
                                    <StackPanel x:Name="QuickTopicPanel" Margin="0,0,0,8"/>

                                </StackPanel>
                            </ScrollViewer>
                            <!--Bottom buttons-->
                            <StackPanel 
                                Grid.Row="1" 
                                Margin="10,10,10,14">

                                <Rectangle 
                                    Height="1" 
                                    Fill="#30363D" 
                                    Margin="0,0,0,10"/>

                                <Button Content=" Clear Chat"
                                        Click="clear_chat"
                                        Margin="0,0,0,4"/>

                                <Button 
                            Content="  Memory Recap"
                            Click="memory_recap"
                            Margin="0,0,0,4"/>
                                <Button 
                            Content="  Voice Toggle"
                             Click="voice_toggle"
                            Margin="0,0,0,4"/>
                                <Button 
                            Content="  Exit"
                            Click="close_button"/>

                            </StackPanel>
                        </Grid>

                    </Border>


                    <Grid
                        x:Name="banner_grid"
                        Grid.Column="1"               
                        >

                        <!--start of banner grid-->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!--head banner-->
                            <RowDefinition Height="*"/>
                            <!--messages-->
                            <RowDefinition Height="Auto"/>
                            <!--input bar-->

                        </Grid.RowDefinitions>

                        <!--header with ascii logo-->

                        <Border
                    Grid.Row="0"
                    Background="#0A0F14"
                    BorderBrush="#30363D"
                    BorderThickness="0,0,0,0"
                    Padding="10,8,10,8"
                            Margin="0,0,0,5"
                    >
                            <!--start of full ascii logo order-->
                            <Grid>
                                <!--start of full ascii logo grid-->
                                <TextBlock
                            FontFamily="Consolas"
                            FontWeight="Bold"
                            FontSize="7"
                            HorizontalAlignment="Center"
