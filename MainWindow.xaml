                                    <TextBlock.Effect>
                                        <DropShadowEffect 
                                Color="#00E5FF"  
                                BlurRadius="1" 
                                ShadowDepth="0" 
                                Opacity="13"
                                />
                                    </TextBlock.Effect> 
                            
