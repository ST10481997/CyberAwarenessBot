                    BlurRadius="30" 
                    ShadowDepth="0" 
                    Opacity="0.8"/>
            </Border.Effect>

            <Grid
                x:Name="title_grid"
                Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
